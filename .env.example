# ── Job Board Credentials ────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
INDEED_EMAIL=
INDEED_PASSWORD=
DICE_EMAIL=
DICE_PASSWORD=
MONSTER_EMAIL=
MONSTER_PASSWORD=

# ── Claude API ───────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...
# Judgment calls: should I apply? confirm submission?
CLAUDE_DECISION_MODEL=claude-sonnet-4-6
# High-volume field filling
CLAUDE_FILL_MODEL=claude-haiku-4-5-20251001

# ── Search Defaults ──────────────────────────────────────────────
SEARCH_KEYWORDS=["SOC analyst","security operations","software engineer"]
SEARCH_LOCATIONS=["Remote","New Jersey"]
SEARCH_DAYS_BACK=7

# ── Application Limits ───────────────────────────────────────────
MAX_APPLICATIONS_PER_DAY=50
DELAY_MIN_SECONDS=10
DELAY_MAX_SECONDS=30

# ── Paths (override if needed, defaults work inside Docker) ──────
DB_PATH=/app/data/jobs.db
SESSIONS_DIR=/app/data/sessions
RESUME_PATH=/app/data/resume.docx
RESUME_OVERRIDES_PATH=/app/data/resume_overrides.json
REPORTS_DIR=/app/reports
